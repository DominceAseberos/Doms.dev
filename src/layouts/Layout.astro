---
import { ClientRouter } from 'astro:transitions';
import GlobalLoader from '../components/GlobalLoader';
import LightEnvironment from '../components/LightEnvironment';
import ThemeBulb from '../components/ThemeBulb';
import FireflyCursor from '../components/FireflyCursor';

import '../index.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Domince Aseberos — Creative Full Stack Developer",
  description = "Domince Aseberos - Selected Work and Portfolio."
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <meta name="description" content={description}>
    <meta name="google-site-verification" content="3IU-JoGuhELqmZFvmqhIbqCj5oZ27gg_m9FjmJbUNao" />
    <meta name="keywords" content="web developer, React, Next.js, GSAP, Supabase, portfolio, Domince Aseberos, frontend developer, creative engineer, Davao, Philippines">
    <meta name="author" content="Domince Aseberos">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://www.dominceaseberos.tech/">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.dominceaseberos.tech/">
    <meta property="og:site_name" content="Domince Aseberos Portfolio">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="https://www.dominceaseberos.tech/og-preview.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="en_PH">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@domince_dev">
    <meta name="twitter:creator" content="@domince_dev">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content="https://www.dominceaseberos.tech/og-preview.png">

    <!-- Preconnect to Google Fonts CDN for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&family=Orbitron:wght@900&family=Audiowide&family=Bebas+Neue&family=Rajdhani:wght@700&family=DM+Mono:wght@300;400;500&family=Syne:wght@400..800&family=DM+Serif+Display:ital@0;1&family=Space+Mono:wght@400;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <ClientRouter />

    <script is:inline>
        // Prevent Flash of Unstyled Content by applying theme immediately
        (function() {
            try {
                const savedTheme = localStorage.getItem('doms-dev-theme');
                const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
                const theme = savedTheme === 'light' || savedTheme === 'dark' 
                    ? savedTheme 
                    : (prefersLight ? 'light' : 'dark');
                
                document.documentElement.dataset.theme = theme;
                document.documentElement.style.colorScheme = theme;
            } catch (e) {}
        })();
    </script>

    <script is:inline>
        // Inline theme initialization (from old index.html)
        (function () {
            try {
                const stored = localStorage.getItem('theme-storage');
                if (stored) {
                    const { state } = JSON.parse(stored);
                    const sliderValue = state?.sliderValue ?? 0;

                    const BODYLINEAR_1 = { start: { r: 49, g: 49, b: 59 }, mid: { r: 94, g: 133, b: 133 }, end: { r: 150, g: 150, b: 150 } };
                    const BODYLINEAR_2 = { start: { r: 27, g: 23, b: 35 }, mid: { r: 145, g: 145, b: 200 }, end: { r: 150, g: 150, b: 150 } };
                    const CONTRAST = { start: { r: 209, g: 217, b: 255 }, mid: { r: 193, g: 193, b: 100 }, end: { r: 255, g: 255, b: 255 } };
                    const BOXCOLORLINEAR_1 = { start: { r: 21, g: 18, b: 38 }, mid: { r: 35, g: 0, b: 255 }, end: { r: 199, g: 120, b: 150 } };
                    const BOXCOLORLINEAR_2 = { start: { r: 38, g: 42, b: 61 }, mid: { r: 87, g: 97, b: 134 }, end: { r: 178, g: 178, b: 150 } };

                    const lerp = (start, end, t) => start + (end - start) * t;
                    let br, bg, bb, bbr, bbg, bbb, cr, cg, cb, r, g, b, lr, lg, lb;

                    if (sliderValue <= 50) {
                        const t = sliderValue / 50;
                        br = lerp(BODYLINEAR_1.start.r, BODYLINEAR_1.mid.r, t); bg = lerp(BODYLINEAR_1.start.g, BODYLINEAR_1.mid.g, t); bb = lerp(BODYLINEAR_1.start.b, BODYLINEAR_1.mid.b, t);
                        bbr = lerp(BODYLINEAR_2.start.r, BODYLINEAR_2.mid.r, t); bbg = lerp(BODYLINEAR_2.start.g, BODYLINEAR_2.mid.g, t); bbb = lerp(BODYLINEAR_2.start.b, BODYLINEAR_2.mid.b, t);
                        cr = lerp(CONTRAST.start.r, CONTRAST.mid.r, t); cg = lerp(CONTRAST.start.g, CONTRAST.mid.g, t); cb = lerp(CONTRAST.start.b, CONTRAST.mid.b, t);
                        r = lerp(BOXCOLORLINEAR_1.start.r, BOXCOLORLINEAR_1.mid.r, t); g = lerp(BOXCOLORLINEAR_1.start.g, BOXCOLORLINEAR_1.mid.g, t); b = lerp(BOXCOLORLINEAR_1.start.b, BOXCOLORLINEAR_1.mid.b, t);
                        lr = lerp(BOXCOLORLINEAR_2.start.r, BOXCOLORLINEAR_2.mid.r, t); lg = lerp(BOXCOLORLINEAR_2.start.g, BOXCOLORLINEAR_2.mid.g, t); lb = lerp(BOXCOLORLINEAR_2.start.b, BOXCOLORLINEAR_2.mid.b, t);
                    } else {
                        const t = (sliderValue - 50) / 50;
                        br = lerp(BODYLINEAR_1.mid.r, BODYLINEAR_1.end.r, t); bg = lerp(BODYLINEAR_1.mid.g, BODYLINEAR_1.end.g, t); bb = lerp(BODYLINEAR_1.mid.b, BODYLINEAR_1.end.b, t);
                        bbr = lerp(BODYLINEAR_2.mid.r, BODYLINEAR_2.end.r, t); bbg = lerp(BODYLINEAR_2.mid.g, BODYLINEAR_2.end.g, t); bbb = lerp(BODYLINEAR_2.mid.b, BODYLINEAR_2.end.b, t);
                        cr = lerp(CONTRAST.mid.r, CONTRAST.end.r, t); cg = lerp(CONTRAST.mid.g, CONTRAST.end.g, t); cb = lerp(CONTRAST.mid.b, CONTRAST.end.b, t);
                        r = lerp(BOXCOLORLINEAR_1.mid.r, BOXCOLORLINEAR_1.end.r, t); g = lerp(BOXCOLORLINEAR_1.mid.g, BOXCOLORLINEAR_1.end.g, t); b = lerp(BOXCOLORLINEAR_1.mid.b, BOXCOLORLINEAR_1.end.b, t);
                        lr = lerp(BOXCOLORLINEAR_2.mid.r, BOXCOLORLINEAR_2.end.r, t); lg = lerp(BOXCOLORLINEAR_2.mid.g, BOXCOLORLINEAR_2.end.g, t); lb = lerp(BOXCOLORLINEAR_2.mid.b, BOXCOLORLINEAR_2.end.b, t);
                    }

                    const root = document.documentElement;
                    root.style.setProperty('--body-Linear-1-rgb', `${Math.round(br)} ${Math.round(bg)} ${Math.round(bb)}`);
                    root.style.setProperty('--body-Linear-2-rgb', `${Math.round(bbr)} ${Math.round(bbg)} ${Math.round(bbb)}`);
                    root.style.setProperty('--contrast-rgb', `${Math.round(cr)} ${Math.round(cg)} ${Math.round(cb)}`);
                    root.style.setProperty('--box-Linear-1-rgb', `${Math.round(r)} ${Math.round(g)} ${Math.round(b)}`);
                    root.style.setProperty('--box-Linear-2-rgb', `${Math.round(lr)} ${Math.round(lg)} ${Math.round(lb)}`);
                }
            } catch (e) {}
        })();
    </script>
</head>
<body>
    <GlobalLoader client:load />
    <LightEnvironment client:load />
    <ThemeBulb client:load />
    <FireflyCursor client:load />
    <div class="nav-hover-zone" aria-hidden="true" ></div>
    
    <div id="smooth-wrapper" class="min-h-screen selection:bg-red-500/30">
        <div id="smooth-content">
            <slot />
        </div>
    </div>
</body>
</html>

                    "columns": [
                        {
                            "id": "pv-overview-col",
                            "columnTitle": "",
                            "blocks": [
                                {
                                    "id": "pv-overview-text",
                                    "type": "text",
                                    "content": "PIXVAULT is a single-page application that centralizes design resources for developers and designers. It pulls live data from multiple external APIs — GIFs from Reddit, icons from Iconify, UI components from shadcn/ui, and illustrations from open sources — and presents them in a unified, searchable interface. No accounts required, no paywalls."
                                }
                            ]
                        }
                    ]
                },

            "contentSections": [
                {
                    "id": "banana-leaf-detector-overview",
                    "sectionTitle": "Overview",
                    "layout": "full",
                    "columns": [
                        {
                            "id": "banana-leaf-detector-overview-col",
                            "columnTitle": "",
                            "blocks": [
                                {
                                    "id": "banana-leaf-detector-overview-text",
                                    "type": "text",
                                    "content": "Banana Leaf Disease Detector is a high-performance machine learning web application built to execute immediate, localized crop diagnostics. To achieve lightweight in-process execution, the system processes plant imagery into a dense 59-dimensional feature fingerprint. This mathematical vector comprises 30 color dimensions (HSV & LAB averages and deviations, plus a 16-bin Hue histogram), 25 texture dimensions (a 4-metric GLCM matrix, an 18-bin Uniform LBP descriptor, 2 HOG summary variables, and Canny edge density), and 4 shape dimensions (area, perimeter, circularity, and aspect ratio). A localized K-Nearest Neighbors (k=5) classifier uses this vector for real-time predictions, supported by a closed-loop active learning system that retrains the model in under 200ms when feedback is received."
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "banana-leaf-detector-arch",
                    "sectionTitle": "Architecture",
                    "layout": "2-equal",
                    "columns": [
                        {
                            "id": "banana-leaf-detector-arch-left",
                            "columnTitle": "Tech Stack",
                            "blocks": [
                                {
                                    "id": "banana-leaf-detector-core",
                                    "type": "chips",
                                    "items": [
                                        "Flask",
                                        "Python 3.12",
                                        "HTML5 / CSS3",
                                        "JavaScript (Vanilla)"
                                    ]
                                },
                                {
                                    "id": "banana-leaf-detector-ml-label",
                                    "type": "heading",
                                    "content": "Machine Learning & CV"
                                },
                                {
                                    "id": "banana-leaf-detector-ml-chips",
                                    "type": "chips",
                                    "items": [
                                        "scikit-learn (KNN)",
                                        "OpenCV (cv2)",
                                        "scikit-image",
                                        "NumPy",
                                        "Pandas"
                                    ]
                                },
                                {
                                    "id": "banana-leaf-detector-db-label",
                                    "type": "heading",
                                    "content": "Cloud Infrastructure"
                                },
                                {
                                    "id": "banana-leaf-detector-db-chips",
                                    "type": "chips",
                                    "items": [
                                        "Firebase Admin SDK",
                                        "Firestore (NoSQL)",
                                        "Chart.js (Visuals)"
                                    ]
                                }
                            ]
                        },
                        {
                            "id": "banana-leaf-detector-arch-right",
                            "columnTitle": "Engineering Decisions",
                            "blocks": [
                                {
                                    "id": "banana-leaf-detector-decisions",
                                    "type": "list",
                                    "items": [
                                        "Dynamic Leaf Masking — Leverages green-channel HSV thresholding with strict numerical bounds of [25, 40, 40] to [90, 255, 255] and executes mathematical morph close/open filters using a (7,7) ellipse kernel.",
                                        "GLCM Quantification — Quantizes raw grayscale pixels into 64 distinct gray levels to extract 4 texture variables (contrast, homogeneity, energy, correlation) at a precise spatial offset distance of 5 pixels and 0 angle.",
                                        "Uniform LBP Processing — Captures microscopic crop surface lesions via local binary patterns with P=8 sampling points, R=1 radius, and uniform method mapping to compute a structured 18-bin histogram.",
                                        "Closed-Loop Retraining Thread — When a prediction error is corrected, the 59-dimensional feature vector is cached and committed to Firestore and retrained in-process under 200ms using the locally cached KNN classifier.",
                                        "Multi-Channel Log Layer — Implements real-time Firestore sockets alongside local logging of offline CSV audit records to prevent agricultural diagnostics data loss."
                                    ]
                                }
                            ]
                        }
                    ]
                },

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Domince Aseberos | Portfolio</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400..800&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0c0c0c;
            --white: #f2f0ed;
            --red: #d63b2f;
            --gray: #444;
            --gray-light: #777;
            --border: rgba(255,255,255,0.07);
        }

        html, body {
            background: var(--bg);
            color: var(--white);
            font-family: 'Syne', sans-serif;
            min-height: 100vh;
            cursor: crosshair;
            overflow-x: hidden;
        }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 48px;
            mix-blend-mode: normal;
        }
        .nav-logo {
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.2em;
            color: var(--gray-light);
            text-transform: uppercase;
        }
        .nav-links {
            display: flex;
            gap: 36px;
            list-style: none;
        }
        .nav-links a {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--gray-light);
            text-decoration: none;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--white); }

        /* ── HERO ── */
        .hero {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            position: relative;
            overflow: hidden;
        }

        /* left half */
        .hero-left {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 0 48px 64px;
            position: relative;
            z-index: 2;
            border-right: 1px solid var(--border);
        }

        .eyebrow {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.22em;
            color: var(--red);
            text-transform: uppercase;
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeUp 0.6s 0.2s ease forwards;
        }

        .hero-name {
            font-size: clamp(52px, 6.5vw, 96px);
            font-weight: 800;
            line-height: 0.92;
            letter-spacing: -0.02em;
            text-transform: uppercase;
            opacity: 0;
            animation: fadeUp 0.7s 0.35s ease forwards;
        }
        .hero-name .line2 {
            color: transparent;
            -webkit-text-stroke: 1px rgba(242,240,237,0.4);
        }

        .hero-desc {
            margin-top: 36px;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            line-height: 1.8;
            color: var(--gray-light);
            max-width: 340px;
            opacity: 0;
            animation: fadeUp 0.7s 0.5s ease forwards;
        }

        .hero-cta {
            margin-top: 48px;
            display: flex;
            gap: 16px;
            align-items: center;
            opacity: 0;
            animation: fadeUp 0.7s 0.65s ease forwards;
        }
        .btn-primary {
            background: var(--red);
            color: var(--white);
            border: none;
            padding: 14px 32px;
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn-primary:hover { opacity: 0.85; }
        .btn-ghost {
            background: transparent;
            color: var(--gray-light);
            border: 1px solid var(--border);
            padding: 14px 32px;
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: color 0.2s, border-color 0.2s;
        }
        .btn-ghost:hover { color: var(--white); border-color: rgba(255,255,255,0.25); }

        /* right half */
        .hero-right {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 0 48px 64px;
            position: relative;
            z-index: 2;
        }

        /* canvas */
        canvas {
            position: absolute;
            inset: 0;
            width: 100%; height: 100%;
            z-index: 0;
            opacity: 0;
            animation: fadeIn 1.2s 0.4s ease forwards;
        }

        /* tags */
        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 40px;
            opacity: 0;
            animation: fadeUp 0.7s 0.75s ease forwards;
            position: relative; z-index: 2;
        }
        .tag {
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--gray-light);
            border: 1px solid var(--border);
            padding: 7px 14px;
            transition: color 0.2s, border-color 0.2s;
        }
        .tag:hover { color: var(--white); border-color: rgba(255,255,255,0.2); }
        .tag.active { color: var(--red); border-color: var(--red); }

        /* metrics */
        .metrics {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: 1px solid var(--border);
            opacity: 0;
            animation: fadeUp 0.7s 0.9s ease forwards;
            position: relative; z-index: 2;
        }
        .metric {
            padding: 24px 0;
            border-right: 1px solid var(--border);
        }
        .metric:last-child { border-right: none; }
        .metric-val {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1;
        }
        .metric-val sup { font-size: 14px; color: var(--red); }
        .metric-lbl {
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.14em;
            color: var(--gray-light);
            text-transform: uppercase;
            margin-top: 6px;
        }

        /* scrolling marquee at center */
        .marquee-wrap {
            position: absolute;
            top: 50%; left: 0; right: 0;
            transform: translateY(-50%);
            overflow: hidden;
            pointer-events: none;
            z-index: 1;
            opacity: 0.04;
        }
        .marquee-track {
            display: flex;
            gap: 48px;
            white-space: nowrap;
            animation: marquee 18s linear infinite;
        }
        .marquee-track span {
            font-size: clamp(80px, 12vw, 180px);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            flex-shrink: 0;
        }

        @keyframes marquee {
            from { transform: translateX(0); }
            to   { transform: translateX(-50%); }
        }

        /* vertical label */
        .v-label {
            position: absolute;
            right: -12px; top: 50%;
            transform: translateY(-50%) rotate(90deg);
            font-family: 'DM Mono', monospace;
            font-size: 8px;
            letter-spacing: 0.24em;
            color: var(--gray);
            text-transform: uppercase;
            z-index: 5;
            white-space: nowrap;
        }

        /* animations */
        @keyframes fadeUp {
            from { opacity:0; transform:translateY(24px); }
            to   { opacity:1; transform:translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity:0; }
            to   { opacity:1; }
        }

        @media (max-width: 768px) {
            .hero { grid-template-columns: 1fr; }
            .hero-left { border-right: none; border-bottom: 1px solid var(--border); padding-top: 120px; }
            .hero-right { padding-top: 40px; }
            .v-label { display: none; }
        }
    </style>
</head>
<body>

<nav>
  <div class="nav-logo">DA — 2025</div>
  <ul class="nav-links">
    <li><a href="#">Work</a></li>
    <li><a href="#">About</a></li>
    <li><a href="#">Lab</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>

<section class="hero">

  <canvas id="c"></canvas>

  <div class="marquee-wrap">
    <div class="marquee-track">
      <span>Motion</span><span>·</span>
      <span>Code</span><span>·</span>
      <span>Design</span><span>·</span>
      <span>Motion</span><span>·</span>
      <span>Code</span><span>·</span>
      <span>Design</span><span>·</span>
    </div>
  </div>

  <div class="hero-left">
    <div class="v-label">Developer × Motion Designer</div>

    <div class="eyebrow">Portfolio — Selected Work</div>

    <h1 class="hero-name">
      Domince<br>
      <span class="line2">Aseberos</span>
    </h1>

    <p class="hero-desc">
      Crafting high-performance web experiences<br>
      where code meets motion. GSAP · WebGL · React.
    </p>

    <div class="hero-cta">
      <button class="btn-primary">View Work</button>
      <button class="btn-ghost">Get in Touch</button>
    </div>
  </div>

  <div class="hero-right">

    <div class="tags">
      <div class="tag active">GSAP</div>
      <div class="tag">WebGL</div>
      <div class="tag">Three.js</div>
      <div class="tag">React</div>
      <div class="tag">GLSL</div>
      <div class="tag">Motion</div>
      <div class="tag">Next.js</div>
    </div>

    <div class="metrics">
      <div class="metric">
        <div class="metric-val">60<sup>fps</sup></div>
        <div class="metric-lbl">Render</div>
      </div>
      <div class="metric" style="padding-left:24px">
        <div class="metric-val">48<sup>+</sup></div>
        <div class="metric-lbl">Projects</div>
      </div>
      <div class="metric" style="padding-left:24px">
        <div class="metric-val">5<sup>yr</sup></div>
        <div class="metric-lbl">Experience</div>
      </div>
    </div>

  </div>

</section>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

const COUNT = 60;
const MAX_DIST = 130;
let mouse = { x: canvas.width / 2, y: canvas.height / 2 };

window.addEventListener('mousemove', e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

const nodes = Array.from({ length: COUNT }, () => ({
  x: Math.random() * canvas.width,
  y: Math.random() * canvas.height,
  vx: (Math.random() - 0.5) * 0.3,
  vy: (Math.random() - 0.5) * 0.3,
  r: Math.random() * 1.2 + 0.5,
  p: Math.random() * Math.PI * 2,
}));

function tick() {
  requestAnimationFrame(tick);
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const W = canvas.width, H = canvas.height;

  nodes.forEach(n => {
    n.x += n.vx; n.y += n.vy; n.p += 0.015;
    if (n.x < 0 || n.x > W) n.vx *= -1;
    if (n.y < 0 || n.y > H) n.vy *= -1;
  });

  // draw edges
  for (let i = 0; i < COUNT; i++) {
    for (let j = i + 1; j < COUNT; j++) {
      const dx = nodes[i].x - nodes[j].x;
      const dy = nodes[i].y - nodes[j].y;
      const d = Math.sqrt(dx * dx + dy * dy);
      if (d < MAX_DIST) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(214,59,47,${(1 - d / MAX_DIST) * 0.18})`;
        ctx.lineWidth = 0.6;
        ctx.moveTo(nodes[i].x, nodes[i].y);
        ctx.lineTo(nodes[j].x, nodes[j].y);
        ctx.stroke();
      }
    }
  }

  // draw nodes
  nodes.forEach(n => {
    const glow = (Math.sin(n.p) + 1) * 0.5;
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(214,59,47,${0.3 + glow * 0.5})`;
    ctx.fill();
  });

  // mouse halo
  const grad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 200);
  grad.addColorStop(0, 'rgba(214,59,47,0.06)');
  grad.addColorStop(1, 'transparent');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);
}
tick();
</script>
</body>
</html>